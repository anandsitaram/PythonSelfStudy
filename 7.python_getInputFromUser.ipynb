   "source": [
    "### To get input from user we use builtin input()\n",
    "name=input(\"What is your name?\")\n",
    "print(\"My name is \",name)\n",
    "\n",
    "# input() always returns string\n",
    "value=input(\"What is your age?\")\n",
    "print(type(value))\n",
    "# convert into int\n",
    "valueInt=int(value)\n",
    "print(type(valueInt))\n",
    "print(\"The age is \",valueInt)\n"
   ],
